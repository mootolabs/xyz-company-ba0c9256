---
const config = {
  "companyName": "XYZ Company",
  "phone": "04104040404",
  "email": "maximooto@hotmail.com",
  "mapQuery": "Brisbane",
  "brandColor": "#0F172A"
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contact - {config.companyName}</title>
    <style>
      :root { --brand-color: #0F172A; }
      body { font-family: system-ui, sans-serif; padding: 40px; max-width: 900px; margin: 0 auto; color: #333; }
      h1 { color: var(--brand-color); margin-bottom: 20px; }
      .intro { margin-bottom: 30px; }
      .contact-info { margin: 30px 0; }
      .contact-info p { margin: 10px 0; font-size: 1.1rem; }
      .address-card { background: #f8f9fa; padding: 20px; border-radius: 8px; margin: 15px 0; }
      .address-card h3 { color: var(--brand-color); margin-bottom: 10px; }
      iframe { width: 100%; height: 400px; border: none; border-radius: 8px; margin-top: 30px; }
    </style>
  </head>
  <body>
    <h1>Contact Us</h1>
    <p class="intro"></p>
    
    <div class="contact-info">
      <p><strong>Phone:</strong> {config.phone}</p>
      <p><strong>Email:</strong> {config.email}</p>
    </div>

    <div class="addresses">
      <div class="address-card">
        <h3>Main Office</h3>
        <p>123 Eagle St</p>
        <p>Brisbane, qld 4000</p>
        <p>Australia</p>
      </div>
    </div>

    <iframe 
      src="https://www.google.com/maps/embed/v1/place?key=YOUR_API_KEY&q=Brisbane"
      allowfullscreen
    ></iframe>
  </body>
</html>