---
const config = {
  "companyName": "XYZ Company",
  "brandColor": "#0F172A"
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>About - {config.companyName}</title>
    <style>
      :root { --brand-color: #0F172A; }
      body { font-family: system-ui, sans-serif; padding: 40px; max-width: 900px; margin: 0 auto; color: #333; }
      h1 { color: var(--brand-color); margin-bottom: 30px; }
      h2 { color: var(--brand-color); margin-top: 30px; margin-bottom: 15px; }
      p { margin-bottom: 20px; line-height: 1.6; }
    </style>
  </head>
  <body>
    <h1>About {config.companyName}</h1>
    <p></p>
    <h2>Our Mission</h2>
    <p></p>
    <h2>Our Values</h2>
    <p>[object Object],[object Object],[object Object],[object Object]</p>
  </body>
</html>